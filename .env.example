# Root env used by docker-compose. Copy to .env and fill in.
# (backend/.env.example documents every backend variable in detail.)

# Public URL the browser uses to reach the frontend (for CORS).
CLIENT_URL=http://localhost:8080

# JWT secrets — REQUIRED. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# AI / storage providers (optional — app uses dev fallbacks if unset).
# LLM is OpenAI-compatible. For Groq: OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=llama-3.3-70b-versatile
HUGGINGFACE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=smart-docs
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
