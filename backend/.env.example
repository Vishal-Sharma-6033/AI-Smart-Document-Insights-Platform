# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed origins for CORS
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
# MongoDB Atlas connection string (or local: mongodb://mongodb:27017/smart-docs)
MONGODB_URI=mongodb://localhost:27017/smart-docs

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary (optional — falls back to local disk if unset) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── LLM (OpenAI-compatible: OpenAI, Groq, Together, etc.) ──
# Leave OPENAI_BASE_URL empty for the official OpenAI API.
# For Groq (llama-3.3-70b-versatile): OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=llama-3.3-70b-versatile

# ── HuggingFace Embeddings (optional — falls back to dev embeddings if unset) ──
HUGGINGFACE_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Pinecone (optional — falls back to in-memory store if unset) ──
PINECONE_API_KEY=
PINECONE_INDEX=smart-docs

# ── Uploads ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
